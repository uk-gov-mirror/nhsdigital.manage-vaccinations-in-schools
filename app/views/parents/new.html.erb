<% content_for :navigation do %>
  <%= govuk_back_link(href: edit_patient_path(@patient)) %>
<% end %>

<%= form_with model: [@patient, @parent], url: patient_parents_path(patient_id: @patient.id) do |f| %>
  <%= f.mavis_error_summary %>

  <% page_title = "Add parent or guardian" %>

    <%= h1 page_title do %>
    <span class="nhsuk-caption-l">
        <%= @patient.full_name %>
    </span>
    <%= page_title %>
    <% end %>

  <%= render "fields", f: %>

  <%= f.govuk_submit "Save" %>
<% end %>
