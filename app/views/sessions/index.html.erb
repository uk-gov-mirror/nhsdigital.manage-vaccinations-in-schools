<%= h1 t(".title") %>

<%= render AppActionLinkComponent.new(
      href: new_session_path,
      text: "Add a new session",
    ) %>

<div class="nhsuk-grid-row">
  <div class="app-grid-column-filters">
    <%= render AppSessionSearchFormComponent.new(
          @form,
          url: sessions_path,
          programmes: @programmes,
          academic_years: true,
        ) %>
  </div>

  <div class="app-grid-column-results">
    <%= render AppSearchResultsComponent.new(@pagy, label: "sessions") do %>
      <% @sessions.each do |session| %>
        <%= render AppSessionCardComponent.new(
              session,
              patient_count: @patient_count_by_session_id.fetch(session.id, 0),
              show_status: true,
              heading_level: 3,
            ) %>
      <% end %>
    <% end %>
  </div>
</div>
