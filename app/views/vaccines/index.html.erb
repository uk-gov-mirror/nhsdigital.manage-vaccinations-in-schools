<%= h1 t(".title") %>

<% @vaccines.each do |vaccine| %>
  <%= render AppCardComponent.new(section: true) do |card| %>
    <% card.with_heading(level: 2) { link_to(vaccine_heading(vaccine), vaccine_path(vaccine)) } %>

    <%= govuk_summary_list do |summary_list|
          summary_list.with_row do |row|
            row.with_key { "Manufacturer" }
            row.with_value { vaccine.manufacturer }
          end
        
          summary_list.with_row do |row|
            row.with_key { "SNOMED code" }
            row.with_value { content_tag(:span, vaccine.snomed_product_code, class: "nhsuk-u-text-break-word app-u-code") }
          end
        end %>

    <%= render AppActionLinkComponent.new(
          href: new_vaccine_batch_path(vaccine),
          text: "Add a new batch",
          aria: { label: "Add a new #{vaccine.brand} batch" },
        ) %>

    <% if (batches = @batches_by_vaccine_id[vaccine.id]).present? %>
      <%= govuk_table do |table| %>
        <%= table.with_head do |head| %>
          <%= head.with_row do |row| %>
            <%= row.with_cell(text: "Batch number") %>
            <%= row.with_cell(text: "Entered date") %>
            <%= row.with_cell(text: "Expiry date") %>
            <%= row.with_cell(text: "Actions") %>
          <% end %>
        <% end %>

        <%= table.with_body do |body| %>
          <% batches.each do |batch| %>
            <% body.with_row do |row| %>
              <% row.with_cell do %>
                <span class="nhsuk-u-text-break-word app-u-code">
                  <%= batch.number %>
                </span>

                <% if batch.id == @todays_batch_id_by_programme_and_vaccine_methods&.dig(vaccine.programme, vaccine.method) %>
                  <br>
                  <span class="nhsuk-caption-m">
                    (Your default)
                  </span>
                <% end %>
              <% end %>
              <% row.with_cell(text: batch.created_at.to_date.to_fs(:long)) %>
              <% row.with_cell(text: batch.expiry&.to_fs(:long) || "Unknown") %>
              <% row.with_cell do %>
                <%= render AppActionListComponent.new do |action_list| %>
                  <% action_list.with_item do %>
                    <%= link_to "Archive", archive_vaccine_batch_path(vaccine, batch),
                                aria: { label: "Archive #{batch.number} batch of #{vaccine.brand}" } %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
