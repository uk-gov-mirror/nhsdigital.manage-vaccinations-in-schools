<% if @new_records_pagy.count.positive? %>
    <h2 class="nhsuk-heading-m">New records</h2>
    <p class="nhsuk-u-reading-width">
        <%= new_records_message %>
    </p>
    <%= render AppDetailsComponent.new(expander: true, sticky: true, id: :new_records, open: @open_sections&.include?(:new_records)) do |c| %>
        <% c.with_summary do %>
          <%= pluralize(@new_records_pagy.count, "new record") %>
          <% if @new_records_pagy.count > @new_records_pagy.limit %>
            (showing <b><%= @new_records_pagy.from %></b> to <b><%= @new_records_pagy.to %></b>)
          <% end %>
        <% end %>
        <%= render AppImportReviewRecordsSummaryComponent.new(changesets: @new_records, pagy: @new_records_pagy, anchor: :new_records) %>
    <% end %>
<% end %>

<% if @auto_matched_records_pagy.count.positive? %>
    <h2 class="nhsuk-heading-m">Records already in Mavis</h2>
    <p class="nhsuk-u-reading-width">
      <%= auto_matched_message %>
    </p>
    <%= render AppDetailsComponent.new(expander: true, sticky: true, id: :auto_matched_records, open: @open_sections&.include?(:auto_matched_records)) do |c| %>
        <% c.with_summary do %>
          <%= pluralize(@auto_matched_records_pagy.count, "record") %> already in Mavis
          <% if @auto_matched_records_pagy.count > @auto_matched_records_pagy.limit %>
            (showing <b><%= @auto_matched_records_pagy.from %></b> to <b><%= @auto_matched_records_pagy.to %></b>)
          <% end %>
        <% end %>
        <%= render AppImportReviewRecordsSummaryComponent.new(changesets: @auto_matched_records, pagy: @auto_matched_records_pagy, anchor: :auto_matched_records) %>
    <% end %>
<% end %>

<% if @inter_team.any? %>
    <h2 class="nhsuk-heading-m">Children moving from another SAIS team's area - resolve after import</h2>
    <p class="nhsuk-u-reading-width">
        <%= inter_team_message %>
    </p>
    <%= render AppDetailsComponent.new(expander: true, sticky: true) do |c| %>
        <% c.with_summary do %>
            <%= pluralize(@inter_team.count, "school move") %> across teams
        <% end %>
        <%= render AppImportReviewSchoolMovesSummaryComponent.new(changesets: @inter_team) %>
    <% end %>

    <% if @inter_team_import_issues.any? %>
        <%= render AppDetailsComponent.new(expander: true, sticky: true) do |c| %>
            <% c.with_summary do %>
                <%= pluralize(@inter_team_import_issues.count, "close match") %> to existing records
            <% end %>
            <%= render AppImportReviewIssuesSummaryComponent.new(import: @import, records: @inter_team_import_issues) %>
        <% end %>
    <% end %>
<% end %>

<% if @import_issues.any? %>
    <h2 class="nhsuk-heading-m">Close matches to existing records - resolve after import</h2>
    <p class="nhsuk-u-reading-width">
        <%= import_issues_message %>
    </p>
    <%= render AppDetailsComponent.new(expander: true, sticky: true, id: :import_issues, open: @open_sections&.include?(:import_issues)) do |c| %>
        <% c.with_summary do %>
          <%= pluralize(@import_issues_pagy.count, "close match") %> to existing records
          <% if @import_issues_pagy.count > @import_issues_pagy.limit %>
            (showing <b><%= @import_issues_pagy.from %></b> to <b><%= @import_issues_pagy.to %></b>)
          <% end %>
        <% end %>
        <%= render AppImportReviewIssuesSummaryComponent.new(import: @import, records: @import_issues, pagy: @import_issues_pagy, anchor: :import_issues) %>
    <% end %>
<% end %>

<% if @school_moves.any? %>
    <h2 class="nhsuk-heading-m">School moves - resolve after import</h2>
    <p class="nhsuk-u-reading-width">
        <%= school_moves_message %>
    </p>
    <%= render AppDetailsComponent.new(expander: true, sticky: true, id: :school_moves, open: @open_sections&.include?(:school_moves)) do |c| %>
        <% c.with_summary do %>
          <%= pluralize(@school_moves_pagy.count, "school move") %>
          <% if @school_moves_pagy.count > @school_moves_pagy.limit %>
            (showing <b><%= @school_moves_pagy.from %></b> to <b><%= @school_moves_pagy.to %></b>)
          <% end %>
        <% end %>
        <%= render AppImportReviewSchoolMovesSummaryComponent.new(changesets: @school_moves, pagy: @school_moves_pagy, anchor: :school_moves) %>
    <% end %>
<% end %>

<% if @skipped_school_moves.any? %>
    <h2 class="nhsuk-heading-m">Records not imported - children at schools in other team areas</h2>
    <p class="nhsuk-u-reading-width">
        <%= skipped_school_moves_message %>
    </p>
    <%= render AppDetailsComponent.new(expander: true, sticky: true) do |c| %>
        <% c.with_summary do %>
            <%= pluralize(@skipped_school_moves.count, "record") %> not imported
        <% end %>
        <%= render AppImportReviewRecordsSummaryComponent.new(changesets: @skipped_school_moves) %>
    <% end %>
<% end %>

<hr class="nhsuk-section-break nhsuk-section-break--visible nhsuk-section-break--l">

<div class="nhsuk-button-group">
    <%= helpers.govuk_button_to approve_button_text, polymorphic_path([:approve, @import]),
                                method: :post %>
    <% if show_cancel_button? %>
        <%= helpers.govuk_button_to cancel_button_text, polymorphic_path([:cancel, @import]),
                                    method: :post,
                                    secondary: true %>
    <% end %>
</div>
